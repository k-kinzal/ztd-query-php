[
  {
    "id": "SQLITE-CONTRACT-GRAMMAR-STRUCTURE",
    "level": "contract",
    "dialect": "sqlite",
    "statement": "WHEN the SQLite constrained grammar is compiled, THEN the designated entry and retained families SHALL remain closed, non-empty, terminating, and reachable.",
    "subject": { "kind": "grammar" },
    "evidence": [
      { "kind": "grammar.no_undefined_references" },
      { "kind": "grammar.no_empty_rules" },
      { "kind": "grammar.entries.present" },
      { "kind": "grammar.entries.terminate" },
      {
        "kind": "grammar.families.reachable",
        "families": [
          "sqlite.statement.any",
          "sqlite.statement.select",
          "sqlite.constraint.select.star_requires_from",
          "sqlite.constraint.select.set_operation",
          "sqlite.constraint.select.values_clause",
          "sqlite.constraint.temporary_object_name_binding",
          "sqlite.statement.insert",
          "sqlite.statement.update",
          "sqlite.statement.delete",
          "sqlite.statement.create_table",
          "sqlite.statement.alter_table",
          "sqlite.statement.drop_table",
          "sqlite.constraint.attach.expression",
          "sqlite.constraint.detach.expression",
          "sqlite.constraint.vacuum.into_expression",
          "sqlite.lex.identifier.context"
        ]
      }
    ]
  },
  {
