      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:NO_SYM", "t:RELEASE_SYM"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:CHAIN_SYM"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:CHAIN_SYM", "t:NO_SYM", "t:RELEASE_SYM"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:NO_SYM", "t:CHAIN_SYM"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:NO_SYM", "t:CHAIN_SYM", "t:RELEASE_SYM"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:NO_SYM", "t:CHAIN_SYM", "t:NO_SYM", "t:RELEASE_SYM"] },
      { "kind": "grammar.rule.not_contains_sequence", "rule": "rollback", "sequence": ["t:ROLLBACK_SYM", "nt:opt_work", "t:AND_SYM", "t:CHAIN_SYM", "t:RELEASE_SYM"] }
    ]
  },
  {
    "id": "MYSQL-CONTRACT-REPLICA-UNTIL",
    "level": "contract",
    "dialect": "mysql",
    "statement": "WHEN START REPLICA UNTIL is refined, THEN file-based UNTIL clauses SHALL keep the required file-and-position pair and stand-alone gaps mode SHALL not combine with file options.",
    "subject": { "kind": "grammar" },
    "evidence": [
      { "kind": "grammar.rule.contains_sequence", "rule": "replica_until", "sequence": ["t:SOURCE_LOG_FILE_SYM", "t:EQ", "nt:TEXT_STRING_sys_nonewline", "t:,", "t:SOURCE_LOG_POS_SYM", "t:EQ", "nt:ulonglong_num"] },
      { "kind": "grammar.rule.contains_sequence", "rule": "replica_until", "sequence": ["t:SQL_AFTER_MTS_GAPS"] },
      { "kind": "grammar.rule.not_contains_sequence", "rule": "replica_until", "sequence": ["nt:source_file_def"] }
    ]
  },
  {
