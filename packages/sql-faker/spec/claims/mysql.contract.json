      { "kind": "grammar.rule.not_contains_sequence", "rule": "source_def", "sequence": ["nt:source_file_def"] },
      { "kind": "grammar.rule.not_contains_sequence", "rule": "source_def", "sequence": ["t:PRIVILEGE_CHECKS_USER_SYM", "t:EQ", "nt:privilege_check_def"] }
