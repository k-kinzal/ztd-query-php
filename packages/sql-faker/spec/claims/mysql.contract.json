[
  {
    "id": "MYSQL-CONTRACT-GRAMMAR-STRUCTURE",
    "level": "contract",
    "dialect": "mysql",
    "statement": "WHEN the MySQL constrained grammar is compiled, THEN the designated entry and retained families SHALL remain closed, non-empty, terminating, and reachable.",
    "subject": { "kind": "grammar" },
    "evidence": [
      { "kind": "grammar.no_undefined_references" },
      { "kind": "grammar.no_empty_rules" },
      { "kind": "grammar.entries.present" },
      { "kind": "grammar.entries.terminate" },
      {
        "kind": "grammar.families.reachable",
        "families": [
          "mysql.statement.any",
          "mysql.statement.select",
          "mysql.statement.insert",
          "mysql.statement.update",
          "mysql.statement.delete",
          "mysql.constraint.transaction.commit",
          "mysql.constraint.transaction.rollback",
          "mysql.constraint.table_value_constructor",
          "mysql.constraint.set_system_variable",
          "mysql.constraint.create_srs",
          "mysql.constraint.signal_sqlstate",
          "mysql.constraint.show_warnings.limit",
          "mysql.constraint.alter_database.encryption",
          "mysql.constraint.change_replication_source",
          "mysql.lex.identifier.context"
        ]
      }
    ]
  },
  {
    "id": "MYSQL-CONTRACT-ROLLBACK-COMBINATION",
