{
    "name": "k-kinzal/ztd-query-mysqli-adapter",
    "description": "MySQLi adapter for ZTD Query",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-mysqli": "*",
        "k-kinzal/ztd-query-php": "@dev",
        "k-kinzal/ztd-query-mysql": "@dev"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92",
        "infection/infection": "^0.28 || ^0.29 || ^0.30 || ^0.31 || ^0.32",
        "k-kinzal/sql-faker": "@dev",
        "k-kinzal/sql-fixture": "@dev",
        "k-kinzal/testcontainers-php": "^0.5.1",
        "nikic/php-fuzzer": "^0.0.11",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11 || ^12 || ^13",
        "k-kinzal/phpstan-custom-rules": "@dev",
        "brianium/paratest": "^6.11 || ^7"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ztd-query-core"
        },
        {
            "type": "path",
            "url": "../ztd-query-mysql"
        },
        {
            "type": "path",
            "url": "../sql-faker"
        },
        {
            "type": "path",
            "url": "../sql-fixture"
        },
        {
            "type": "path",
            "url": "../phpstan-custom-rules"
        }
    ],
    "autoload": {
        "psr-4": {
            "ZtdQuery\\Adapter\\Mysqli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Fuzz\\": "fuzz/"
        }
    },
    "scripts": {
        "test": "paratest --processes=auto",
        "test:unit": "phpunit tests/Unit/",
        "test:integration": "phpunit tests/Integration/",
        "lint": [
            "@format:check",
            "phpstan analyse --memory-limit=512M"
        ],
        "format": "php-cs-fixer fix --allow-risky=yes",
        "format:check": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "fuzz": [
            "@fuzz:robustness",
            "@fuzz:correctness:select",
            "@fuzz:correctness:insert",
            "@fuzz:correctness:update",
            "@fuzz:correctness:delete"
        ],
        "fuzz:robustness": "php-fuzzer fuzz fuzz/fuzz_robustness_execute.php --corpus=fuzz/corpus/robustness-execute",
        "fuzz:correctness:select": "php-fuzzer fuzz fuzz/fuzz_correctness_select.php --corpus=fuzz/corpus/correctness-select",
        "fuzz:correctness:insert": "php-fuzzer fuzz fuzz/fuzz_correctness_insert.php --corpus=fuzz/corpus/correctness-insert",
        "fuzz:correctness:update": "php-fuzzer fuzz fuzz/fuzz_correctness_update.php --corpus=fuzz/corpus/correctness-update",
        "fuzz:correctness:delete": "php-fuzzer fuzz fuzz/fuzz_correctness_delete.php --corpus=fuzz/corpus/correctness-delete",
        "infection": "infection --threads=max --show-mutations --no-progress"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
